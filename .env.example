PORT=3000
NODE_ENV=development
TRUST_PROXY=true
APP_VERSION=1.0.0
BUILD_SHA=local

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=kgmao_db
DB_CONNECT_RETRIES=5
DB_CONNECT_RETRY_DELAY_MS=5000

# JWT Configuration
# Development placeholder only. Production requires a unique random value with at least 32 characters.
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=24h

# Security / Networking
# Development default only. Production requires explicit trusted origins, for example https://app.example.com.
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=100
PASSWORD_RESET_TOKEN_TTL_MINUTES=15
MFA_ENFORCEMENT_ENABLED=false
VITE_MFA_ENFORCEMENT_ENABLED=false
MFA_ISSUER=KGMAO
MFA_BACKUP_CODES_COUNT=10
SHUTDOWN_TIMEOUT_MS=15000
