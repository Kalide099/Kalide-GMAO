# ============================================================
# KGMAO Environment Variables - copy to .env and fill values
# .env is gitignored - NEVER commit real secrets
# ============================================================

# For local development:
PORT=3000
NODE_ENV=development
TRUST_PROXY=true
APP_VERSION=1.0.0
BUILD_SHA=local

# For Hostinger production, use:
# PORT=3000          (must match nginx proxy_pass port)
# NODE_ENV=production

# Database Configuration (Hostinger: hPanel > Databases)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=kgmao_db
DB_CONNECT_RETRIES=5
DB_CONNECT_RETRY_DELAY_MS=5000

# For Hostinger production DB, use:
# DB_HOST=srv1319.hstgr.io
# DB_USER=u633695266_gmaouser
# DB_PASSWORD=YOUR_DB_PASSWORD
# DB_NAME=u633695266_kgmao

# JWT Configuration - REQUIRED 32+ random chars in production
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=24h

# Security / Networking
# Production requires explicit origin: https://kgmao.com
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=100
PASSWORD_RESET_TOKEN_TTL_MINUTES=15
MFA_ENFORCEMENT_ENABLED=false
VITE_MFA_ENFORCEMENT_ENABLED=false
MFA_ISSUER=KGMAO
MFA_BACKUP_CODES_COUNT=10
SHUTDOWN_TIMEOUT_MS=15000

# SMTP Email Configuration (Hostinger)
# Required for transactional emails: registration, password reset, account approval
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=support@kgmao.com
SMTP_PASS=your_email_password_here
MAIL_FROM_ADDRESS=support@kgmao.com
MAIL_FROM_NAME=KGMAO
APP_URL=https://kgmao.com
