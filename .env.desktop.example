# Desktop-only environment overrides for KGMAO Desktop
# Copy to .env.desktop and adjust values for each tenant machine.

# Local backend port used by the Electron desktop shell
DESKTOP_BACKEND_PORT=5000

# Backend DB settings (local/offline tenant DB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=kgmao_db

# Required for production mode. Replace before launch with a unique random value of at least 32 characters.
JWT_SECRET=replace-with-tenant-specific-random-secret-32-plus-chars

# Desktop mode allows wildcard CORS for the local shell only.
CORS_ORIGIN=*
NODE_ENV=production
APP_VERSION=desktop-local
BUILD_SHA=desktop-local-build
