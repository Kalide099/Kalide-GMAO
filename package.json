{
  "name": "kgmao-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "i18n-check": "node scripts/check-i18n.js",
    "dev": "npm run i18n-check && concurrently -n \"BACKEND,FRONTEND\" -c \"green,blue\" --kill-others \"npm run backend\" \"npm run frontend\"",
    "backend": "npm --prefix backend run dev",
    "frontend": "npm --prefix frontend run dev",
    "init-db": "npm --prefix backend run init-db",
    "extract-locales": "node scripts/extract-missing.js",
    "sync-locales": "node sync_locales.js",
    "install-all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "build": "npm run install-all && npm --prefix frontend run build && node scripts/copy-dist.js",
    "start": "node server.js"
  },
  "main": "server.js",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^7.1.0",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.9.2",
    "uuid": "^9.0.1",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}

