{
  "name": "kgmao-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"green,blue\" --kill-others \"npm run backend\" \"npm run frontend\"",
    "backend": "npm --prefix backend run dev",
    "frontend": "npm --prefix frontend run dev",
    "desktop:build:web": "npm --prefix frontend run build",
    "desktop:start": "npm run desktop:build:web && electron .",
    "desktop:pack": "npm run desktop:build:web && electron-builder --dir",
    "desktop:dist": "npm run desktop:build:web && electron-builder --win nsis",
    "quality:backend": "node scripts/quality-backend-check.js",
    "quality:frontend": "npm --prefix frontend run lint && npm --prefix frontend run build",
    "quality": "npm run quality:backend && npm run quality:frontend",
    "ci": "npm run quality",
    "release:backup": "powershell -ExecutionPolicy Bypass -File scripts/release/backup-dist.ps1",
    "release:rollback": "powershell -ExecutionPolicy Bypass -File scripts/release/rollback-dist.ps1",
    "release:backup-db": "powershell -ExecutionPolicy Bypass -File scripts/release/backup-db.ps1",
    "release:restore-db": "powershell -ExecutionPolicy Bypass -File scripts/release/restore-db.ps1",
    "postinstall": "npm install --prefix backend && npm install --prefix frontend --include=dev && npm run build --prefix frontend",
    "build": "npm install --prefix backend && npm install --prefix frontend --include=dev && npm run build --prefix frontend",
    "start": "node server.js"
  },
  "main": "desktop/main.js",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^7.1.0",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.9.2",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "uuid": "^14.0.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2"
  },
  "build": {
    "appId": "com.kalide.kgmao",
    "productName": "KGMAO Desktop",
    "icon": "desktop/icon.png",
    "files": [
      "desktop/**/*",
      "backend/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".env.desktop.example",
        "to": ".env.desktop.example"
      }
    ],
    "directories": {
      "output": "desktop-dist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}

